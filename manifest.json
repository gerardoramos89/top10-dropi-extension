{
  "manifest_version": 3,
  "name": "Top 10 — Tracker de Ventas y Rentabilidad",
  "version": "1.1.1",
  "description": "Tu ranking de productos, rentabilidad real y progreso de ventas, siempre a un clic en el navegador.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": [
    "https://graph.facebook.com/*",
    "https://api.gumroad.com/*",
    "https://api.emailjs.com/*"
  ]
}
